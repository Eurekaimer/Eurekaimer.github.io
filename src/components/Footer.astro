---
import type { HTMLAttributes } from "astro/types";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border flex flex-col items-center gap-4 border-t py-6 text-sm sm:py-5"
  >
    <div class="text-muted-foreground flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center">
      <span>Copyright &#169; 2024-{currentYear}</span>
      <span class="hidden sm:inline">|</span>
      <a href="https://icp.gov.moe/?keyword=20252030" target="_blank">
        萌ICP备20252030号
      </a>
      <span class="hidden sm:inline">|</span>
      <span>
        Running for <span id="site-runtime">...</span>
      </span>
      <span class="hidden sm:inline">|</span>
      <span>
        Made with
        <a href="https://github.com/satnaing/astro-paper" target="_blank">
          AstroPaper
        </a>
      </span>
    </div>
  </div>
</footer>

<script>
  const startTime = new Date("2024-10-28T00:00:00+08:00").getTime();

  function updateRuntime() {
    const target = document.querySelector("#site-runtime");
    if (!target) return;

    const diff = Date.now() - startTime;
    const seconds = Math.floor(diff / 1000) % 60;
    const minutes = Math.floor(diff / 60000) % 60;
    const hours = Math.floor(diff / 3600000) % 24;
    const days = Math.floor(diff / 86400000);

    target.textContent = `${days}d ${hours}h ${minutes}m ${seconds}s`;
  }

  updateRuntime();
  setInterval(updateRuntime, 1000);
</script>
