---
type Props = {
  title?: string;
  mapping?: "pathname" | "url" | "title" | "og:title" | "specific" | "number";
  term?: string;
};

const { title = "Discussion", mapping = "pathname", term } = Astro.props;
---

<section class="border-border mt-12 border-t pt-8">
  <h2 class="mb-4 text-2xl font-semibold tracking-wide">{title}</h2>
  <script
    is:inline
    src="https://giscus.app/client.js"
    data-repo="Eurekaimer/Eurekaimer.github.io"
    data-repo-id="R_kgDON3QK-w"
    data-category="Announcements"
    data-category-id="DIC_kwDON3QK-84Cm7VD"
    data-mapping={mapping}
    data-term={term}
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="preferred_color_scheme"
    data-lang="zh-CN"
    crossorigin="anonymous"
    async
  ></script>
</section>
