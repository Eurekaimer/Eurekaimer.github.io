---
// ============================================================
// 导入模块 — 一般不需要修改这里
// ============================================================
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const homePath = getRelativeLocaleUrl(locale, "");
---

<!-- ============================================================
  Layout 是整页的容器，控制 <head> 标签（标题、描述、SEO 等）。
  - title: 浏览器标签页标题
  - description: SEO 描述，用于搜索引擎和社交分享
  ============================================================ -->
<Layout
  title="Eurekaimer"
  description="A simple homepage for Eurekaimer."
>
  <!-- ========== 页眉导航栏 ========== -->
  <Header />

  <!-- ========== 页面主体内容 ========== -->
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <!-- ============================================================
      【区块 1】Hero 头像区
      修改你的名字、简介、头像、链接按钮
      - <h1>: 你的名字/标题
      - <p>: 个人简介
      - <LinkButton>: 链接按钮（Notes、Blog、GitHub 等）
      - <img>: 头像图片，替换 public/profile.jpg 即可
      ============================================================ -->
    <section id="hero" class="border-border border-b pt-10 pb-10 sm:pt-16 sm:pb-14">
      <div class="grid gap-8 sm:grid-cols-[3fr_2fr] sm:items-center">
        <div>
          <!-- 你的名字 -->
          <h1 class="my-4 text-4xl leading-tight font-bold sm:text-5xl">
            Eurekaimer
          </h1>

          <!-- 个人简介 — 分段描述，修改时每段一个 <p> -->
          <div class="max-w-2xl space-y-4 text-lg leading-8">
            <p>
              I am a lifelong learner majoring in Statistics at Nankai University, with a passion for probability, mathematics, computer science, and tools that make thinking feel lighter.
            </p>
            <p>
              I love Yuri/GL anime, the gentle worlds of Houbunsha and Kyoto Animation, and games such as Slay the Spire and Counter-Strike.
            </p>
            <p>
              Eurekaimer — <span lang="grc">εὕρηκα</span> × aimer — is my small signature for curiosity, affection, and the wish to find what I love and love what I find.
            </p>
            <p>
              「Wir müssen wissen. Wir werden wissen!」 Don’t hesitate to reach out through the social links.
            </p>
          </div>

        </div>
        <!-- 右栏：标语 + 头像 -->
        <div class="flex flex-col items-center gap-4 sm:items-end">
          <!-- 标语（对准头像上方） -->
          <p class="text-accent text-center text-2xl italic font-light tracking-wide sm:text-3xl">
            「小鞠知花は最高の推し」
          </p>
          <!-- 头像区：不规则圆角框 -->
          <div
            class="flex aspect-square w-full items-center justify-center p-2"
            style="
              border-radius: 42% 58% 48% 52% / 45% 40% 55% 50%;
              border: 2px solid var(--accent, #b91c1c);
            "
          >
            <img
              src="/profile.jpg"
              alt="Eurekaimer profile image"
              width="260"
              height="260"
              loading="eager"
              class="bg-muted h-full w-full object-cover shadow-sm"
              style="
                border-radius: 40% 60% 52% 48% / 43% 42% 58% 48%;
              "
            />
          </div>
        </div>

        <!-- 导航链接：跨两列居中，| 分隔 -->
        <div class="text-muted-foreground col-span-2 flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-lg">
          <span class="text-accent font-bold whitespace-nowrap">
            <span class="text-accent/40 mr-0.5 text-xl align-[-0.15em] select-none" aria-hidden="true">「</span>
            神様、どうして私に鳥かごの開け方を教えたの
            <span class="text-accent/40 ml-0.5 text-xl align-[-0.15em] select-none" aria-hidden="true">」</span>
          </span>
          <span aria-hidden="true">|</span>
          <a href="https://www.eurekaimer.icu/Stathelper/" class="fancy-link">Notes</a>
          <span aria-hidden="true">|</span>
          <a href="https://www.eurekaimer.icu/blog/" class="fancy-link">Daily Blog</a>
          <span aria-hidden="true">|</span>
          <a href="https://github.com/Eurekaimer" class="fancy-link">GitHub</a>
          <span aria-hidden="true">|</span>
          <a href={getRelativeLocaleUrl(locale, "about")} class="fancy-link">About</a>
          <span aria-hidden="true">|</span>
          <a href={getRelativeLocaleUrl(locale, "friends")} class="fancy-link">Friends</a>
        </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ========== 页脚（版权、运行时间等） ========== -->
  <Footer />
</Layout>

<!-- ============================================================
  脚本：记录返回 URL，供其他页面"返回首页"使用，不需要修改
  ============================================================ -->
<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
